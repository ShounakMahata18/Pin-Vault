{
  "manifest_version": 3,
  "name": "Quick Pin",
  "version": "1.0.0",
  "description": "Pin pages to your portal with a snapshot",

  "permissions": [
    "contextMenus",
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/popup.html"
  }
}